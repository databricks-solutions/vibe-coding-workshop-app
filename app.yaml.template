# =============================================================================
# Databricks App Configuration (TEMPLATE)
# =============================================================================
# Generated by: vibe2value configure
# Source: app.yaml.template
#
# This file is auto-generated. Edit user-config.yaml instead, then run:
#   ./vibe2value configure
# =============================================================================
name: __APP_NAME__
description: "AI-Powered Development Workflow - Vibe Coding Workshop"

# Entry point
command:
  - "python"
  - "app.py"

# =============================================================================
# Environment Variables
# =============================================================================
env:
  # Runtime
  - name: PYTHONUNBUFFERED
    value: "1"
  - name: PORT
    value: "8000"
  
  # LLM Model endpoint
  - name: DATABRICKS_SERVING_ENDPOINT
    value: "__SERVING_ENDPOINT__"
  
  # ---------------------------------------------------------------------------
  # Lakebase PostgreSQL Configuration
  # ---------------------------------------------------------------------------
  - name: LAKEBASE_HOST
    value: "__LAKEBASE_HOST__"
  
  - name: LAKEBASE_DATABASE
    value: "databricks_postgres"
  
  - name: LAKEBASE_SCHEMA
    value: "__LAKEBASE_SCHEMA__"
  
  - name: LAKEBASE_PORT
    value: "5432"
  
  # NOTE: LAKEBASE_USER is NOT set here. When running on Databricks Apps,
  # the Lakebase resource link (Step 4c) injects PGUSER automatically with
  # the correct service principal identity. Hardcoding a user email here
  # causes auth failures because the app runs as a service principal.
  
  # Lakebase Autoscaling endpoint name (format: projects/{id}/branches/{id}/endpoints/{id})
  # When set, the app uses Autoscaling mode with SDK token rotation.
  # When empty, falls back to Provisioned mode (PGPASSWORD from resource link).
  - name: ENDPOINT_NAME
    value: "__ENDPOINT_NAME__"

  # Toggle Lakebase (set to "false" for YAML fallback)
  - name: USE_LAKEBASE
    value: "true"

# Health check endpoint
health_check:
  path: /health
  interval_seconds: 30
  timeout_seconds: 10
  failure_threshold: 3
